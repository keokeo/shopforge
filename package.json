{
  "name": "shopforge",
  "version": "0.1.0",
  "private": true,
  "description": "ShopForge - 现代化电商独立站",
  "scripts": {
    "dev:storefront": "pnpm --filter storefront dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:backend": "cd apps/backend && ./venv/bin/uvicorn main:app --reload --port 8000",
    "dev:all": "concurrently \"pnpm dev:storefront\" \"pnpm dev:admin\" \"pnpm dev:backend\"",
    "build:storefront": "pnpm --filter storefront build",
    "build:admin": "pnpm --filter admin build",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
